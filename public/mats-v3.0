<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>MATS V3.0 — Legendary Scanner</title>
<style>
:root{
  --bg:#05080d;--panel:#0d1520;--panel2:#111d2b;--line:#23364a;--text:#eef6ff;--muted:#9fb0c2;
  --green:#22c55e;--red:#ef4444;--yellow:#facc15;--orange:#fb923c;--blue:#38bdf8;--purple:#a78bfa;
}
*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--text);font-family:Arial,Helvetica,sans-serif}button,input,select{font-family:inherit}
.hidden{display:none!important}.app{min-height:100vh}.login-wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background:radial-gradient(circle at top,#122238,#05080d 60%)}
.login-card{width:min(480px,100%);background:var(--panel);border:1px solid var(--line);border-radius:18px;padding:24px;box-shadow:0 20px 70px rgba(0,0,0,.4)}
.logo{font-size:28px;font-weight:800;letter-spacing:.5px}.subtitle{color:var(--muted);margin:8px 0 20px}.role-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.role-btn{border:1px solid var(--line);background:var(--panel2);color:var(--text);padding:16px;border-radius:14px;font-weight:700;cursor:pointer}.role-btn:hover{border-color:var(--blue)}
.topbar{height:58px;display:flex;align-items:center;justify-content:space-between;padding:0 16px;border-bottom:1px solid var(--line);background:#07101a;position:sticky;top:0;z-index:10}.brand{font-weight:900}.role-pill{color:#001018;background:var(--blue);padding:6px 10px;border-radius:999px;font-size:12px;font-weight:800}.logout{background:transparent;color:var(--muted);border:1px solid var(--line);border-radius:10px;padding:8px 12px;cursor:pointer}
.tabs{display:flex;gap:8px;overflow:auto;padding:10px 12px;border-bottom:1px solid var(--line);background:#08111c}.tab{white-space:nowrap;background:var(--panel);border:1px solid var(--line);color:var(--muted);border-radius:999px;padding:9px 14px;cursor:pointer;font-weight:700}.tab.active{color:#001018;background:var(--blue);border-color:var(--blue)}
.content{padding:14px;max-width:1400px;margin:auto}.card{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:14px;margin-bottom:14px}.scanner-head{display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap}.status{color:var(--muted);font-size:13px}.subtabs{display:flex;gap:8px;overflow:auto;margin-top:12px}.subtab{background:#0b1320;color:var(--muted);border:1px solid var(--line);border-radius:12px;padding:10px 12px;cursor:pointer;font-weight:700}.subtab.active{background:#13283a;color:var(--text);border-color:var(--blue)}
.table-wrap{overflow:auto;border:1px solid var(--line);border-radius:14px;margin-top:12px}table{border-collapse:collapse;width:100%;min-width:980px}th,td{padding:10px 9px;border-bottom:1px solid rgba(255,255,255,.08);text-align:left;font-size:13px}th{color:var(--muted);background:#0a1320;position:sticky;top:0}tr{cursor:pointer}tr:hover{background:#111c2a}.badge{display:inline-block;border-radius:999px;padding:4px 8px;font-weight:800;font-size:12px}.good{background:rgba(34,197,94,.18);color:var(--green);border:1px solid rgba(34,197,94,.35)}.warn{background:rgba(250,204,21,.16);color:var(--yellow);border:1px solid rgba(250,204,21,.35)}.bad{background:rgba(239,68,68,.16);color:var(--red);border:1px solid rgba(239,68,68,.35)}.blue{background:rgba(56,189,248,.18);color:var(--blue);border:1px solid rgba(56,189,248,.35)}.purple{background:rgba(167,139,250,.18);color:var(--purple);border:1px solid rgba(167,139,250,.35)}
.dashboard-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:14px}@media(max-width:900px){.dashboard-grid{grid-template-columns:1fr}.role-grid{grid-template-columns:1fr}}
.dash-title{display:flex;align-items:center;justify-content:space-between;gap:10px}.ticker-big{font-size:28px;font-weight:900}.signal-big{font-size:16px;font-weight:900}.dash-table{min-width:0}.dash-table td:first-child{color:var(--muted);font-weight:700}.dash-table td:last-child{text-align:right;font-weight:900}.result-cell{border-radius:10px;padding:6px 8px;display:inline-block;min-width:120px;text-align:center;color:#06110a}.result-green{background:var(--green)}.result-yellow{background:var(--yellow);color:#161100}.result-red{background:var(--red);color:#fff}.action-row{display:flex;gap:10px;margin-top:14px}.primary,.danger,.neutral{flex:1;border:0;border-radius:14px;padding:14px;font-size:16px;font-weight:900;cursor:pointer}.primary{background:var(--green);color:#06110a}.danger{background:var(--red);color:white}.neutral{background:#1f2937;color:white;border:1px solid var(--line)}
.kpi-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}.kpi{background:var(--panel2);border:1px solid var(--line);border-radius:14px;padding:12px}.kpi-label{font-size:12px;color:var(--muted);font-weight:700}.kpi-value{font-size:20px;font-weight:900;margin-top:5px}.small-note{color:var(--muted);font-size:12px;margin-top:10px;line-height:1.4}.empty{color:var(--muted);text-align:center;padding:28px}.settings-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}@media(max-width:700px){.settings-grid{grid-template-columns:1fr}.content{padding:10px}.card{padding:10px}table{min-width:900px}th,td{font-size:12px;padding:8px 7px}.ticker-big{font-size:24px}}
.input{width:100%;background:#07101a;border:1px solid var(--line);border-radius:12px;color:var(--text);padding:12px}.save{background:var(--blue);color:#001018;border:0;border-radius:12px;padding:12px;font-weight:900;cursor:pointer}
</style>
</head>
<body>
<div id="login" class="login-wrap">
  <div class="login-card">
    <div class="logo">MATS V3.0</div>
    <div class="subtitle">Mongol Auto Trading System — Legendary Scanner Prototype</div>
    <div class="role-grid">
      <button class="role-btn" onclick="login('Admin')">Admin Login</button>
      <button class="role-btn" onclick="login('Trader')">Trader Login</button>
      <button class="role-btn" onclick="login('Trial User')">Trial User Login</button>
      <button class="role-btn" onclick="login('Automation')">Automation Login</button>
    </div>
    <div class="small-note">Prototype only. Use a protected backend before live/paper execution.</div>
  </div>
</div>
<div id="app" class="app hidden">
  <div class="topbar"><div><span class="brand">MATS V3.0</span> <span id="rolePill" class="role-pill"></span></div><button class="logout" onclick="logout()">Logout</button></div>
  <div class="tabs">
    <button class="tab active" data-page="scanner" onclick="showPage('scanner')">Legendary Scanner</button>
    <button class="tab" data-page="dashboard" onclick="showPage('dashboard')">Dashboard</button>
    <button class="tab" data-page="tradelog" onclick="showPage('tradelog')">Trade Log</button>
    <button class="tab" data-page="settings" onclick="showPage('settings')">Settings</button>
  </div>
  <main class="content">
    <section id="scanner" class="page">
      <div class="card">
        <div class="scanner-head"><div><b>Legendary Scanner</b><div class="status">Runs only when a universe sub-tab is opened. Live data preferred; 30-sec refresh fallback.</div></div><div id="scanStatus" class="status">Ready</div></div>
        <div class="subtabs">
          <button class="subtab active" onclick="openUniverse('sp500')">S&P 500 — Top 80 → Top 50</button>
          <button class="subtab" onclick="openUniverse('nasdaq')">Nasdaq Composite — Top 10% → Top 50%</button>
          <button class="subtab" onclick="openUniverse('russell')">Russell — Top 10% → Top 50%</button>
        </div>
        <div class="table-wrap"><table><thead><tr><th>Ticker</th><th>Signal</th><th>Score</th><th>Smart Money</th><th>Trend</th><th>Edge</th><th>Risk/Reward</th><th>Momentum</th><th>Action</th></tr></thead><tbody id="scannerBody"></tbody></table></div>
      </div>
    </section>
    <section id="dashboard" class="page hidden">
      <div id="dashboardEmpty" class="card empty">Tap a scanner result to open its MMG-style dashboard.</div>
      <div id="dashboardContent" class="hidden dashboard-grid">
        <div class="card">
          <div class="dash-title"><div><div id="dashTicker" class="ticker-big">—</div><div id="dashSub" class="status">Legendary Dashboard</div></div><div id="dashSignal" class="signal-big badge blue">—</div></div>
          <div class="table-wrap"><table class="dash-table"><tbody id="dashTable"></tbody></table></div>
          <div class="action-row"><button class="danger" onclick="passTrade()">Pass</button><button id="acceptExitBtn" class="primary" onclick="acceptOrExitTrade()">Accept</button></div>
        </div>
        <div class="card"><b>Live Data Panel</b><div class="kpi-grid" id="kpis"></div><div class="small-note">Prototype values use Polygon where available and mock Legendary calculations until the full V9.9K-3 JS engine is ported.</div></div>
      </div>
    </section>
    <section id="tradelog" class="page hidden">
      <div class="card"><b>Trade Log</b><div class="table-wrap"><table><thead><tr><th>Ticker</th><th>Signal</th><th>Entry</th><th>Entry Time</th><th>Exit</th><th>Exit Time</th><th>P/L %</th><th>Score</th><th>Status</th></tr></thead><tbody id="tradeLogBody"></tbody></table></div></div>
    </section>
    <section id="settings" class="page hidden">
      <div class="card"><b>Prototype Settings</b><div class="settings-grid" style="margin-top:12px"><div><label class="status">Polygon API Key</label><input id="apiKeyInput" class="input" placeholder="Paste Polygon key for local/private testing" /></div><div><label class="status">Refresh Fallback</label><select id="refreshSelect" class="input"><option value="30000">30 seconds</option><option value="60000">60 seconds</option><option value="300000">5 minutes</option></select></div></div><button class="save" style="margin-top:12px" onclick="saveSettings()">Save Settings</button><div class="small-note">Do not publish a live key in a public GitHub repo. For production, move keys to a backend or Netlify Function.</div></div>
    </section>
  </main>
</div>
<script>
// MATS V3.0 Prototype Only. For GitHub/public Netlify, do NOT publish a real API key here.
const DEFAULT_POLYGON_API_KEY = "PASTE_POLYGON_API_KEY_HERE";
let POLYGON_API_KEY = localStorage.getItem('polygonKey') || DEFAULT_POLYGON_API_KEY;
let fallbackMs = Number(localStorage.getItem('refreshMs') || 30000);
let currentRole = null, currentUniverse = 'sp500', selected = null, refreshTimer = null;
let scannerRows = [], tradeLog = JSON.parse(localStorage.getItem('matsTradeLog') || '[]');
const universes = {
  sp500:['NVDA','MSFT','AAPL','AMZN','META','GOOGL','AVGO','TSLA','JPM','WMT','LLY','ORCL','V','MA','NFLX','XOM','COST','HD','PG','JNJ','BAC','PLTR','AMD','CRM','ABBV','KO','PEP','CSCO','CVX','WFC','MCD','IBM','GE','ABT','PM','TMO','GS','MRK','RTX','CAT','AXP','NOW','ISRG','QCOM','DIS','INTU','UBER','BKNG','VZ','T'],
  nasdaq:['NVDA','MSFT','AAPL','AMZN','META','GOOGL','AVGO','TSLA','COST','NFLX','AMD','PEP','CSCO','TMUS','ADBE','INTU','QCOM','TXN','AMAT','MU','PANW','LRCX','KLAC','ISRG','BKNG','REGN','VRTX','ADP','MELI','PYPL','MRVL','CRWD','ABNB','ADSK','SBUX','GILD','MDLZ','CSX','MAR','ORLY','FTNT','TEAM','DDOG','ROST','IDXX','KDP','EA','CTAS','FAST','ODFL'],
  russell:['SMCI','MSTR','COIN','RIVN','SOFI','HOOD','IONQ','RKLB','AFRM','UPST','CVNA','DKNG','LCID','CHWY','BROS','AI','PATH','FUBO','QS','PLUG','OPEN','RIOT','MARA','WULF','HIMS','TOST','CAVA','CELH','WING','DUOL','APP','U','RBLX','SNOW','NET','MDB','ZS','OKTA','TTD','DOCU','ROKU','PINS','ETSY','BILL','RUN','ENPH','FSLR','SEDG','BE','BLNK']
};
function login(role){currentRole=role;document.getElementById('login').classList.add('hidden');document.getElementById('app').classList.remove('hidden');document.getElementById('rolePill').textContent=role;openUniverse('sp500');renderTradeLog();}
function logout(){location.reload()}
function showPage(id){document.querySelectorAll('.page').forEach(p=>p.classList.add('hidden'));document.getElementById(id).classList.remove('hidden');document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('active',t.dataset.page===id));}
function openUniverse(u){currentUniverse=u;document.querySelectorAll('.subtab').forEach((b,i)=>b.classList.toggle('active',['sp500','nasdaq','russell'][i]===u));runScan();}
function saveSettings(){POLYGON_API_KEY=document.getElementById('apiKeyInput').value.trim()||DEFAULT_POLYGON_API_KEY;fallbackMs=Number(document.getElementById('refreshSelect').value);localStorage.setItem('polygonKey',POLYGON_API_KEY);localStorage.setItem('refreshMs',fallbackMs);runScan();}
function hashNum(s){let h=0;for(let i=0;i<s.length;i++)h=(h*31+s.charCodeAt(i))>>>0;return h;}
function badgeClass(score){return score>=80?'good':score>=70?'warn':'bad'}
function signalClass(sig){return sig==='B2O'?'blue':sig==='S2O'?'bad':sig==='S2C'?'good':sig==='B2C'?'warn':'warn'}
function opportunity(score){return score>=70?'result-green':score>=40?'result-yellow':'result-red'}
function mockLegendary(ticker, price){const h=hashNum(ticker+currentUniverse);const sig=['B2O','S2O','Wait','B2O','S2C'][h%5];const score=60+(h%39);const edge=45+(h%54);const rr=((h%30)/10+1).toFixed(1);const smart=sig==='S2O'?'Institution Selling':sig==='B2O'?'Institution Buying':h%3===0?'Manipulation':h%3===1?'Bull Trap':'Bear Trap';const trend=sig==='S2O'?'Downtrend':sig==='B2O'?'Uptrend':'Transition';const mom=score>=85?'Strong':score>=72?'Medium':'Weak';const t1=sig==='S2O'?price*0.985:price*1.015;const t2=sig==='S2O'?price*0.97:price*1.03;return {ticker,price,signal:sig,score,smart,trend,edge,rr,momentum:mom,station:t2,direction:sig==='S2O'?'South':sig==='B2O'?'North':'Balance',entry:null,t1,t2,action:'New'};}
async function getPrice(ticker){if(!POLYGON_API_KEY||POLYGON_API_KEY.includes('PASTE_')) return 50+(hashNum(ticker)%250)+(Math.random()*2-1);try{const r=await fetch(`https://api.polygon.io/v2/last/trade/${ticker}?apiKey=${POLYGON_API_KEY}`);const j=await r.json();return j?.results?.p || 50+(hashNum(ticker)%250);}catch(e){return 50+(hashNum(ticker)%250)+(Math.random()*2-1)}}
async function runScan(){clearInterval(refreshTimer);document.getElementById('scanStatus').textContent='Scanning '+currentUniverse.toUpperCase()+'...';const list=universes[currentUniverse];const rows=[];for(const t of list){const p=await getPrice(t);rows.push(mockLegendary(t,p));}rows.sort((a,b)=>b.score-a.score);scannerRows=rows.slice(0,currentUniverse==='sp500'?50:Math.ceil(rows.length*.5));renderScanner();document.getElementById('scanStatus').textContent='Last refresh: '+new Date().toLocaleTimeString();refreshTimer=setInterval(runScan,fallbackMs);}
function renderScanner(){const tb=document.getElementById('scannerBody');tb.innerHTML='';scannerRows.forEach(r=>{const tr=document.createElement('tr');tr.onclick=()=>openDashboard(r.ticker);tr.innerHTML=`<td><b>${r.ticker}</b></td><td><span class="badge ${signalClass(r.signal)}">${r.signal}</span></td><td><span class="badge ${badgeClass(r.score)}">${r.score}/100</span></td><td>${r.smart}</td><td>${r.trend}</td><td>${r.edge}/100</td><td>${r.rr} R/R</td><td>${r.momentum}</td><td>${r.action}</td>`;tb.appendChild(tr);});}
function openDashboard(ticker){selected=scannerRows.find(r=>r.ticker===ticker);showPage('dashboard');document.getElementById('dashboardEmpty').classList.add('hidden');document.getElementById('dashboardContent').classList.remove('hidden');renderDashboard();}
function renderDashboard(){if(!selected)return;document.getElementById('dashTicker').textContent=selected.ticker;document.getElementById('dashSignal').textContent=selected.signal;document.getElementById('dashSignal').className='signal-big badge '+signalClass(selected.signal);document.getElementById('dashSub').textContent=`${selected.direction} • Score ${selected.score}/100`;const legendScore=[selected.smart.includes('Institution')?1:0,selected.trend!=='Transition'?1:0,selected.edge>=70?1:0,Number(selected.rr)>=2?1:0,selected.momentum==='Strong'?1:0].reduce((a,b)=>a+b,0);const rows=[['Price',selected.price.toFixed(2),''],['Station',`${selected.station.toFixed(2)} / ${Math.abs((selected.station-selected.price)/selected.price*100).toFixed(2)}%`,''],['Direction',selected.direction,''],['Smart Money',selected.smart,selected.smart.includes('Institution')?'result-green':'result-yellow'],['Trend',selected.trend,selected.trend==='Transition'?'result-yellow':'result-green'],['Edge',selected.edge+'/100',opportunity(selected.edge)],['Risk/Reward',selected.rr+' R/R',Number(selected.rr)>=2?'result-green':Number(selected.rr)>=1?'result-yellow':'result-red'],['Momentum',selected.momentum,selected.momentum==='Strong'?'result-green':selected.momentum==='Medium'?'result-yellow':'result-red'],['Legend Score',legendScore+'/5',legendScore>=4?'result-green':legendScore>=3?'result-yellow':'result-red'],['Entry',selected.entry?selected.entry.toFixed(2):'-',''],['T1',`${selected.t1.toFixed(2)} (${selected.rr}R)`,''],['T2',`${selected.t2.toFixed(2)} (${(Number(selected.rr)*1.5).toFixed(1)}R)`,''],['Action',selected.action,selected.action==='Accepted'?'result-green':selected.action==='New'?'result-yellow':'result-red']];document.getElementById('dashTable').innerHTML=rows.map(([k,v,c])=>`<tr><td>${k}</td><td>${c?`<span class="result-cell ${c}">${v}</span>`:v}</td></tr>`).join('');document.getElementById('acceptExitBtn').textContent=selected.action==='Accepted'?'Exit':'Accept';document.getElementById('kpis').innerHTML=[['Live Price',selected.price.toFixed(2)],['Signal',selected.signal],['Score',selected.score+'/100'],['Refresh',new Date().toLocaleTimeString()]].map(([a,b])=>`<div class="kpi"><div class="kpi-label">${a}</div><div class="kpi-value">${b}</div></div>`).join('');}
function passTrade(){if(!selected)return;scannerRows=scannerRows.filter(r=>r.ticker!==selected.ticker);selected.action='Passed';renderScanner();selected=null;document.getElementById('dashboardContent').classList.add('hidden');document.getElementById('dashboardEmpty').classList.remove('hidden');showPage('scanner');}
function acceptOrExitTrade(){if(!selected)return;if(selected.action!=='Accepted'){selected.action='Accepted';selected.entry=selected.price;tradeLog.push({id:Date.now(),ticker:selected.ticker,signal:selected.signal,entry:selected.price,entryTime:new Date().toLocaleString(),exit:null,exitTime:null,score:selected.score,status:'Open'});}else{const item=[...tradeLog].reverse().find(x=>x.ticker===selected.ticker&&x.status==='Open');if(item){item.exit=selected.price;item.exitTime=new Date().toLocaleString();item.pnl=((item.exit-item.entry)/item.entry*100)*(item.signal==='S2O'?-1:1);item.status='Closed';}scannerRows=scannerRows.filter(r=>r.ticker!==selected.ticker);selected.action='Exited';}localStorage.setItem('matsTradeLog',JSON.stringify(tradeLog));renderScanner();renderTradeLog();if(selected.action==='Exited'){selected=null;document.getElementById('dashboardContent').classList.add('hidden');document.getElementById('dashboardEmpty').classList.remove('hidden');showPage('scanner');}else renderDashboard();}
function renderTradeLog(){const tb=document.getElementById('tradeLogBody');tb.innerHTML='';if(!tradeLog.length){tb.innerHTML='<tr><td colspan="9" class="empty">No trades recorded yet.</td></tr>';return;}tradeLog.slice().reverse().forEach(x=>{const tr=document.createElement('tr');tr.innerHTML=`<td><b>${x.ticker}</b></td><td>${x.signal}</td><td>${x.entry?.toFixed(2)||'-'}</td><td>${x.entryTime||'-'}</td><td>${x.exit?.toFixed(2)||'-'}</td><td>${x.exitTime||'-'}</td><td>${x.pnl==null?'-':x.pnl.toFixed(2)+'%'}</td><td>${x.score}/100</td><td>${x.status}</td>`;tb.appendChild(tr);});}
document.getElementById('apiKeyInput').value=POLYGON_API_KEY.includes('PASTE_')?'':POLYGON_API_KEY;document.getElementById('refreshSelect').value=String(fallbackMs);
</script>
</body>
</html>
